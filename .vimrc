setlocal ts=2 sw=2
" Use spaces instead of tabs
set expandtab

" Set the width of a tab character to 2 spaces for display purposes
set tabstop=2

" Set the number of spaces for autoindent and << / >>
set shiftwidth=2

" Use 2 spaces when pressing Tab or Backspace
set softtabstop=2

" Enable automatic indentation
set autoindent
set smartindent
filetype plugin indent on
